@charset "utf-8";



/********* 아웃로그인 *********/
.ol {position:relative;margin:0 0 10px;background:#fff;text-align:center;border:1px solid #dbdee4}
.ol h2 {width:0;height:0;overflow:hidden}
.ol_wr {position:relative;border:1px solid #d2d8e2}

#ol_s_before {padding:25px}
#ol_s_before input[type=text], #ol_s_before input[type=password] {width:100%;background:#fbfbfc;height:40px;padding:0 80px 0 5px;border:0}
#ol_s_before input[type=password] {margin-top:-1px;border-top:1px solid #e3e7ee}
#ol_s_submit {position:absolute;right:0;top:-1px;width:85px;height:80px;font-weight:bold;font-size:1.083em}
.ol_before_btn {float:right;margin:5px 0;color:#aaa;line-height:1em}
.ol_before_btn a {display:inline-block;float:left;padding:5px;border:1px solid #d5d9dd;border-radius:3px;color:#999}
#ol_password_lost {margin-left:5px;padding-left:8px;background:url('img/division-border.gif') left 4px no-repeat;}

.ol_auto_wr:after {display:block;visibility:hidden;clear:both;content:""}
#ol_auto {float:left;display:inline-block;margin-top:20px;line-height:20px}
#ol_auto label {color:#555;vertical-align:top;padding-left:5px}
#ol_auto label span {margin-top:2px}
.ol_auto_wr:after {display:block;visibility:hidden;clear:both;content:""}

#ol_svc {display:inline-block;float:right;margin-top:20px;line-height:20px}

#ol_after_hd {padding:20px;height:90px;position:relative}
#ol_after_hd strong {display:block;margin-bottom:5px}
#ol_after_hd .btn_admin {display:inline-block;padding:5px;text-align:center}
#ol_after_hd .profile_img {position:absolute;left:20px;top:20px;display:inline-block;margin:0 0 10px}
#ol_after_hd .profile_img img {width:50px;height:50px;border-radius:50%}
#ol_after_info {position:absolute;bottom:0;right:0;color:#000;background:#fff;width:20px;line-height:20px;height:20px;overflow:hidden;border-radius:50%;-webkit-box-shadow:0 1px 5px #d6d6d6;-moz-box-shadow:0 1px 5px #d6d6d6;box-shadow:0 1px 5px #d6d6d6}

.ol_m_info {padding-left:65px;text-align:left}
.ol_m_info a.btn_b04 {border:1px solid #d5d9dd;padding:5px;background:#fff;color:#555;padding:5px}

#ol_after_private {border-top:1px solid #f2f2fe;margin:0;padding:10px 0;list-style:none}
#ol_after_private:after {display:block;visibility:hidden;clear:both;content:""}
#ol_after_private li {float:left;width:33.333%}

#ol_after_private a {display:block;color:#525d71}
#ol_after_private span {display:block}
#ol_after_private i {margin:5px 0;color:#fff;font-size:1em}

#ol_after_memo, #ol_after_pt {border-right:1px solid #f5f5f5}
#ol_after_memo strong,
#ol_after_pt strong,
#ol_after_scrap strong {display:inline-block;font-weight:normal;margin:5px 0;padding:1px 5px;background:#17bb9c;color:#fff;border-radius:10px}
#ol_after_pt strong {background:#8e74ef}
#ol_after_scrap strong {background:#ff9138}

#ol_after_btn {margin:0 0 15px}
#ol_after_btn a {display:inline-block;padding:0 10px;line-height:25px;border-radius:3px;font-weight:bold;vertical-align:baseline}
#ol_after_btn a.btn_admin {border:1px solid #c90d1e}

#sns_outlogin {border:0 !important;background:#fff !important;padding:0 !important;margin-top:0 !important}
.login-sns h3 {color:#000 !important;text-align:left !important;margin-top:20px !important;padding-top:0 !important}
.sns-wrap {text-align:left !important}


/* 인기검색어 */
#popular {display:block;text-align:left;margin-bottom:10px;}
#popular h2 {font-size:1.3em;}
#popular h2 i {display:inline-block;margin-left:5px;color:#000;font-weight:bold}
#popular a {display:inline-block;height:22px;line-height:20px;background:#e1eaf3;color:#687389;margin-bottom:5px;margin-right:2px;padding:0 10px}
#popular a:hover {background:#2faeaf;border-color:#694ecc;color:#fff}



/* 최근게시물 공지 스킨 (latest) */
.notice:after {display:block;visibility:hidden;clear:both;content:""}
.notice {clear:both;position:relative;overflow-x:hidden;overflow:auto;border:1px solid #dbdee4;background:#fff}
.notice h2 {font-size:1.2em;padding:20px 20px 0}
.notice h2 a {color:#000}
.notice h2 i {display:inline-block;margin-left:5px}
.notice ul {clear:both;padding:0 20px 20px}
.notice li {position:relative;text-overflow:ellipsis;overflow:hidden;white-space:nowrap;font-size:1.2em;border-bottom:1px solid #f0f0f1;padding:5px 0 5px 10px;line-height:30px}
.notice li:last-child {border:0}
.notice li:after {position:absolute;top:20px;left:0;content:"";width:3px;height:3px;border-radius:5px;background:#aca7a7}
.notice li a {float:left;color:#262a46}
.notice li .lock_icon {display:inline-block;line-height:14px;width:16px;font-size:0.833em;color:#4f818c;background:#cbe3e8;text-align:center;border-radius:2px;font-size:12px;border:1px solid #a2c6ce;vertical-align:top}
.notice li .new_icon {line-height:16px;background:#3fd49e;border:1px solid #32c791;font-size:0.833em;color:#fff;padding:0 5px;width:16px;height:16px;border-radius:3px;margin-left:5px;text-align:center;vertical-align:middle}	
.notice li .cnt_cmt {line-height:16px;background:#fff;border:1px solid #cdcdcd;font-size:0.833em;color:#3598dc;padding:0 5px;width:16px;height:16px;border-radius:10px;margin-left:5px;text-align:center;vertical-align:middle}




/* 최근게시물 베이직 슬라이드 스킨 (latest) */
.lt {position:relative;min-height:520px;overflow:hidden;float:left;width:33.3%}
.lt:after {display:block;visibility:hidden;clear:both;content:""}
.lt_even {margin-left:20px;width:calc(33.3% - 20px)}
.lt_slider_li {}
.lt_slider_li ul {list-style:none;padding:20px 5px 0}
.lt_slider_li > strong {display:block;font-size:1.3em;padding:0 5px}
.lt_slider_li li {position:relative;border-bottom:1px solid #f3f3f3;text-align:left;padding:10px 0}
.lt_slider_li li:after {display:block;visibility:hidden;clear:both;content:""}
.lt_slider_li li:last-child {border-bottom:0}
.lt_slider_li .lt_title {display:block;padding:15px 20px;text-align:left;font-size:1.2em;color:#010101}

.lt .lt_img {display:inline-block;position:absolute;left:0;top:10px}
.lt .lt_img img {width:115px !important;height:80px}
.lt .lt_cnt {display:inline-block;}
.lt .lt_tit {height:24px;font-size:1.2em;vertical-align:top;font-weight:bold;overflow:hidden}
.lt .lt_subject_pre {clear:both;display:block;margin:10px 0;color:#a09b9b;line-height:20px;max-height:42px;overflow:hidden}
.lt .lt_subject_pre:after {display:block;visibility:hidden;clear:both;content:""}
.lt .lt_info {position:relative;margin:5px 0 0;line-height:24px;color: #666;vertical-align:top}
.lt .lt_info .lt_date {margin-left:5px;padding-left:8px;background:url('img/division-border.gif') left 4px no-repeat;color:#838383}
.lt .profile_img img {border-radius:50%;width:20px !important;display:inline-block !important;vertical-align:top}

.lt li .fa-download {width:16px;height:16px;line-height:16px;background:#ecaa30;color:#fff;text-align:center;font-size:10px;border-radius:2px}
.lt li .fa-link {width:16px;height:16px;line-height:16px;background:#2aa974;color:#fff;text-align:center;font-size:10px;border-radius:2px}
.lt li .fa-heart {color:#ff0000}
.lt li .fa-lock {display:inline-block;width:16px;line-height:14px;font-size:0.833em;color:#fff;background:#262b88;text-align:center;border-radius:2px;font-size:12px;border:1px solid #262b88}
.lt li .new_icon {display:inline-block;width:16px;line-height:14px;font-size:0.833em;color:#fff;background:#3fd49e;border:1px solid #32c791;text-align:center;border-radius:2px;margin-left:3px}
.lt li .hot_icon {display:inline-block;width:16px;line-height:14px;font-size:0.833em;color:#fff;background:#ff7261;border:1px solid #e75341;text-align:center;border-radius:2px}
.lt li .fa-caret-right {color:#bbb}
.lt li.empty_li {text-align:center;padding:40px 0;color:#777}

.lt .bx-controls {padding:0 15px;text-align:center}
.lt .bx-controls:after {display:block;visibility:hidden;clear:both;content:""}
.lt .bx-pager {display:block;line-height:25px;height:25px;text-align:center;vertical-align:bottom}
.lt .bx-pager-item {display:inline-block}
.lt .bx-pager-item a {display:inline-block;float:left;background:#d9dee9;text-indent:-9999px;border-radius:10px;width:8px;height:8px;margin:0 2px;vertical-align:middle}
.lt .bx-pager-item a.active {background:#5d5285}
.lt .bx-controls-direction {display:inline-block;position:absolute;top:0;right:0;}
.lt .bx-controls-direction i {font-weight:bold;font-size:1.4em}
.lt .bx-next {position:absolute;top:40px;right:40px;display:inline-block;width:25px;height:25px;line-height:25px;text-align:center;border:1px solid #d9dde3;background:#fff}
.lt .bx-prev {position:absolute;top:40px;right:64px;display:inline-block;width:25px;height:25px;line-height:25px;text-align:center;border:1px solid #d9dde3;background:#fff}


@media (max-width:980px){
	.lt {width:100% !important;min-height:inherit;margin-bottom:20px;padding:0;border:0;background: #f8f8f8;}
	.lt, .lt:nth-child(3n) {width:49%}
	.lt_even {margin-left:0}
	.lt .bx-controls-direction {top:-20px;right:-15px}
	#popular {display:block;text-align:left;padding:0;border: 0;background:#f8f8f8;margin-bottom:10px;}
}



/* 최근게시물 갤러리 탭 슬라이더 스킨 (latest) */
.gal_tab {position:relative;min-height:520px;border:1px solid #dbdee4;margin-bottom:20px}
.gal_tab:after {display:block;visibility:hidden;clear:both;content:""}

#tab_top {position:absolute;left:0;top:0;background:#fff;border-right:1px solid #dbdee4;width:185px;height:100%}
#tab_bottom {padding:0 0 0 185px}

.pic_tab {height:auto;background:#fff}
.pic_tab h2 {position:absolute;font-size:0;text-indent:-9999em;line-height:0;overflow:hidden}
.pic_tab .bx-controls {display:none}
.pic_tab .pic_tab_wrap {}
.pic_tab .pic_tab_wrap:after {display:block;visibility:hidden;clear:both;content:""}
.pic_tab .pic_tab_ul {position:relative;width:100%}
.pic_tab .pic_tab_ul li:nth-child(4n) {clear:both}
.pic_tab .pic_tab_ul li.empty_li {text-align:center !important;width:100% !important;line-height:300px}

.pic_tab_heading {padding:0}
.pic_tab_heading a {position:relative;display:inline-block;padding:15px 10px;text-align:left;border-bottom:0;font-size:1.2em;font-weight:bold;cursor:pointer}
.pic_tab_heading h3 {display:inline-block;text-align:left;font-size:1.2em}
.pic_tab_heading a.active {color:#f68931}
.pic_tab_heading a.active:after {position:absolute;left:0;bottom:0;width:100%;height:3px;background:#f68931;content:'';z-index:9}
.pic_tab_heading:after {display:block;visibility:hidden;clear:both;content:''}

.gal_tab ul {padding:0 10px}
.gal_tab ul li {position:relative;padding:15px 0;text-align:left;border-bottom:1px solid #f3f3f3}
.gal_tab ul li:last-child {border-bottom:0}
.gal_tab ul li:after {display:block;visibility:hidden;clear:both;content:""}
.gal_tab ul li .lt_img {position:absolute;left:0;top:15px;margin-right:10px;overflow:hidden}
.gal_tab ul li .lt_img img {width:115px;height:80px}
.gal_tab ul li .lt_cnt {padding-left:125px}
.gal_tab ul li .lt_tit {height:24px;font-size:1.2em;vertical-align:top;font-weight:bold;overflow:hidden}
.gal_tab ul li .lt_subject_pre {clear:both;display:block;margin:10px 0;color:#a09b9b;line-height:20px;max-height:42px;overflow:hidden}
.gal_tab ul li .lt_subject_pre:after {display:block;visibility:hidden;clear:both;content:""}
.gal_tab ul li .lt_date {margin-left:5px;padding-left:8px;background:url('img/division-border.gif') left 4px no-repeat;color:#838383}


.gal_tab li a:hover {color:#3598dc}
.gal_tab li .fa-heart {color:#ff0000}
.gal_tab li .fa-lock {display:inline-block;width:16px;line-height:14px;font-size:0.833em;color:#fff;background:#262b88;text-align:center;border-radius:2px;font-size:12px;border:1px solid #262b88}
.gal_tab li .new_icon {display:inline-block;width:16px;line-height:14px;font-size:0.833em;color:#fff;background:#3fd49e;border:1px solid #32c791;text-align:center;border-radius:2px;margin:5px 0 5px 3px}
.gal_tab li .hot_icon {display:inline-block;width:16px;line-height:14px;font-size:0.833em;color:#fff;background:#ff7261;border:1px solid #e75341;text-align:center;border-radius:2px;margin:5px 0 5px 3px}
.gal_tab li .fa-caret-right {color:#bbb}

.lt_nick {color:#999}
.lt_nick img {border-radius:50%}

.tabs {}
.tabs:after {display:block;visibility:hidden;clear:both;content:""}

[role="tablist"] {padding:32px 0;overflow:visible}
[role="tab"] {position:relative;margin:0;font-weight:bold;width:100%;text-align:left;padding:10px 15px;border:0;background:#fff;overflow:visible;font-size:1em}
[role="tab"]:hover::before,
[role="tab"]:focus::before,
[role="tab"][aria-selected="true"]::before {position:absolute;bottom:-1px;top:0;right:0;left:0;border-left:3px solid #fd1a5d;content:''}
[role="tab"][aria-selected="true"] {outline:0}
[role="tab"][aria-selected="true"]::after {}
[role="tab"][aria-selected="true"]:not(:focus):not(:hover)::before {border-left:3px solid #fd1a5d;height:100%}

[role="tab"]:hover,
[role="tab"]:focus,
[role="tab"]:active {outline:0;border-radius:0;color:inherit;color:#fd1a5d}
[role="tab"]:hover::before,
[role="tab"]:focus::before {border-color:#fd1a5d}

[role="tabpanel"] {position:relative;z-index:2}

@media (max-width:720px){
	#tab_top {width:100%;position:inherit;background:pink}
	#tab_bottom {padding:0}
	[role="tablist"] {padding:0 10px;border-bottom:1px solid #ececec;background:#fff}
	[role="tab"] {display:inline-block;width:auto;float:left;padding:15px 10px}
	[role="tab"]:hover::before,
	[role="tab"]:focus::before,
	[role="tab"][aria-selected="true"]::before {bottom:-1px;top:0;right:0;left:0;border-left:0;border-bottom:3px solid #fd1a5d}
	[role="tab"][aria-selected="true"] {outline:0}
	[role="tab"][aria-selected="true"]::after {}
	[role="tab"][aria-selected="true"]:not(:focus):not(:hover)::before {border-left:0;border-bottom:3px solid #fd1a5d}
}


#visit {display:flex}
#visit:after {display:block;visibility:hidden;clear:both;content:""}
#visit h2 {position:absolute;font-size:0;text-indent:-9999em;line-height:0;overflow:hidden}
#visit ul {display:inline-block;padding:0 20px}
#visit ul:after {display:block;visibility:hidden;clear:both;content:""}
#visit li {display:inline-block;float:left;font-size:1.083em;padding:6.5px 15px;font-weight:500;color:#c3c7d0}
#visit li span {margin-left:10px;color:#fff}

@media (max-width:1300px){
	#visit ul {padding:0 10px 0 0}
	#visit li {padding:9px 10px}
}

@media (max-width:1200px){
	#visit {background:#5c6982;position:relative}
	#visit ul {padding:5px 0;width:100%}
	#visit li {width:50%;text-align:left;padding:5px 10px}
	#visit li.visit_admin {position:absolute;right:8px;top:-51px;width:42px;height:40px;padding:10px;border:0;margin-left:0;text-align:center}
}

.fee1 {padding:0 3px 1px; background:#2f409f; color:#fff;font-size: 11px;}
.fee2 {margin-left:5px; padding:0 3px 1px; background:#888; color:#fff;font-size: 11px;}



/* 20240402 kyj 수정*/ 
@media(max-width:991px){
	.mob_lt{background:transparent}
	.lt_slider_li > strong{font-size:15px;margin-bottom:10px; color:#ff5629;  border:1px solid #ff5629; border-radius:20px; padding:5px;}
	.mob_lt .table_list th,.mob_lt .table_list tr{background:transparent}

}
