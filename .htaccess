# 메인 페이지
RewriteRule ^main/?$ index.php?p=main [QSA,L]

# 수기결제
RewriteRule ^pay/?$ index.php?p=manual_payment [QSA,L]
RewriteRule ^pay/new/?$ index.php?p=manual_payment_module [QSA,L]
RewriteRule ^pay/cancel/?$ index.php?p=manual_payment_cancel [QSA,L]
RewriteRule ^pay/config/?$ index.php?p=manual_payment_config [QSA,L]
RewriteRule ^pay/merchant/?$ index.php?p=member_keyin_config [QSA,L]

# URL결제 (공개 결제 페이지 - 9자리 영숫자 코드)
RewriteRule ^pay/([A-Za-z0-9]{9})$ url_payment_public.php?code=$1 [QSA,L]

# 결제 관련
RewriteRule ^txn/merchant/?$ index.php?p=payment_member [QSA,L]
RewriteRule ^txn/missing/?$ index.php?p=payment_loss [QSA,L]
RewriteRule ^txn/daily/?$ index.php?p=payment_day [QSA,L]
RewriteRule ^txn/cancel/?$ index.php?p=cancel_payment [QSA,L]
RewriteRule ^txn/memo/?$ index.php?p=payment_memo [QSA,L]
RewriteRule ^txn/fds/?$ index.php?p=payment_fds [QSA,L]
RewriteRule ^txn/?$ index.php?p=payment [QSA,L]

# 정산 관련
RewriteRule ^calc/simple/?$ index.php?p=settlement_master2 [QSA,L]
RewriteRule ^calc/store/?$ index.php?p=settlement_master3 [QSA,L]
RewriteRule ^calc/?$ index.php?p=settlement [QSA,L]

# 차액정산
RewriteRule ^diff/member/?$ index.php?p=sftp_member [QSA,L]
RewriteRule ^diff/tid/?$ index.php?p=sftp_tid [QSA,L]
RewriteRule ^diff/data/?$ index.php?p=sftp_payment [QSA,L]
RewriteRule ^diff/files/?$ index.php?p=sftp_data [QSA,L]

# 수수료/TID 관리
RewriteRule ^fee/alt/?$ index.php?p=tid_fee2 [QSA,L]
RewriteRule ^fee/tid/?$ index.php?p=tid_pay [QSA,L]
RewriteRule ^fee/?$ index.php?p=tid_fee [QSA,L]
RewriteRule ^manage/tid/?$ index.php?p=adm_tid [QSA,L]

# 회원/접속 정보
RewriteRule ^access/?$ index.php?p=member_info [QSA,L]
RewriteRule ^store/?$ index.php?p=member [QSA,L]

# 게시판
RewriteRule ^board/?$ index.php?p=bbs [QSA,L]

# 로그아웃
RewriteRule ^logout/?$ index.php?p=logout [QSA,L]

# ========================================
# API v1 Endpoints
# ========================================
# URL결제 API
RewriteRule ^api/v1/url-payment/create/?$ api/v1/url_payment_create.php [QSA,L]
RewriteRule ^api/v1/url-payment/list/?$ api/v1/url_payment_list.php [QSA,L]
RewriteRule ^api/v1/url-payment/detail/?$ api/v1/url_payment_detail.php [QSA,L]
RewriteRule ^api/v1/url-payment/cancel/?$ api/v1/url_payment_cancel.php [QSA,L]
RewriteRule ^api/v1/url-payment/resend-sms/?$ api/v1/url_payment_resend_sms.php [QSA,L]
RewriteRule ^api/v1/url-payment/pg-list/?$ api/v1/url_payment_pg_list.php [QSA,L]
